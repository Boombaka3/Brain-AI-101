generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum EvaluationSource {
  pre_course
  post_course
}

model CourseModule {
  id            String         @id
  title         String
  description   String?
  sortOrder     Int
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  quizQuestions QuizQuestion[]
}

model QuizQuestion {
  id               String              @id
  moduleId         String
  section          String?
  sectionTitle     String?
  concept          String?
  prompt           String              @db.Text
  correctOptionId  String
  explanation      String              @db.Text
  options          Json
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  module           CourseModule        @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  quizAttemptLinks QuizAttemptAnswer[]

  @@index([moduleId])
}

model QuizAttempt {
  id                    String                @id @default(cuid())
  sessionId             String
  source                String                @default("course-evaluation")
  startedAt             DateTime?
  completedAt           DateTime?
  submittedAt           DateTime              @default(now())
  score                 Int
  maxScore              Int
  passed                Boolean
  moduleBreakdown       Json
  selectedAnswers       Json
  createdAt             DateTime              @default(now())
  answers               QuizAttemptAnswer[]
  linkedEvaluations     EvaluationSubmission[]

  @@index([sessionId, submittedAt])
}

model QuizAttemptAnswer {
  id               String       @id @default(cuid())
  attemptId        String
  questionId       String
  selectedOptionId String
  isCorrect        Boolean
  createdAt        DateTime     @default(now())
  attempt          QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question         QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Restrict)

  @@unique([attemptId, questionId])
  @@index([questionId])
}

model EvaluationSubmission {
  id              String            @id @default(cuid())
  sessionId       String
  source          EvaluationSource
  startedAt       DateTime?
  completedAt     DateTime?
  submittedAt     DateTime          @default(now())
  skipped         Boolean           @default(false)
  likertResponses Json
  openResponses   Json
  createdAt       DateTime          @default(now())
  quizAttemptId   String?
  quizAttempt     QuizAttempt?      @relation(fields: [quizAttemptId], references: [id], onDelete: SetNull)

  @@index([source, submittedAt])
  @@index([sessionId, submittedAt])
}

model UserProgress {
  id                    String   @id @default(cuid())
  userId                String   @unique
  currentView           String?
  completedViews        Json
  moduleSectionProgress Json
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
